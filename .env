# Configurazione locale di Client Configurator.
# Puoi lasciare questi valori cosi' come sono: il database gira solo su questo PC.

# Nome del database e credenziali (usate dal container MariaDB e dal backend)
DB_NAME=palestra
DB_USER=palestra
DB_PASSWORD=palestra_pwd
DB_ROOT_PASSWORD=root_pwd

# Carica dati dimostrativi al primo avvio (true/false)
SEED_DEMO=true
